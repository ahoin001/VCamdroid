{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "vcamdroid",
  "version-string": "1.3.3",
  "description": "VCamdroid - Use your phone as a Windows webcam",
  "builtin-baseline": "57d5665ca81cb063946952dbd58f5190cb48216e",
  "dependencies": [
    "asio",
    "wxwidgets",
    {
      "name": "ffmpeg",
      "features": ["avcodec", "avformat", "avutil", "swscale"]
    }
  ],
  "features": {
    "ios-usb": {
      "description": "iOS USB tunneling via libusbmuxd (requires iTunes/Apple Devices on Windows)",
      "dependencies": [
        "libusbmuxd",
        "libimobiledevice"
      ]
    }
  }
}
